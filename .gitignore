# --- Virtual environments ---
.venv/
venv/

# --- Python bytecode ---
__pycache__/
*.py[cod]
*.pyo

# --- Build artefacts (generated by uv build / hatchling) ---
dist/
build/
*.egg-info/

# --- Test and analysis caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# --- Local temporary directories (e.g. clean-install test venvs) ---
.tmp/

# --- Environment files (real secrets — never commit these) ---
.env
.env.*
# Keep .env.example — it is documentation, not secrets
!.env.example
# Keep the intentional broken-project fixture (contains only fake values)
!examples/broken-projects/missing-env-gitignore/.env

# --- OS artefacts ---
.DS_Store
Thumbs.db
